# Server
PORT=3000

# Postgres
DATABASE_URL=postgres://notify:notify@localhost:5432/notifyqueue

# Redis (used by BullMQ for the queue, locks, and rate-limit counters)
REDIS_URL=redis://localhost:6379

# Worker
WORKER_CONCURRENCY=5
SIMULATED_FAILURE_RATE=0.3
MAX_ATTEMPTS=5
BASE_BACKOFF_MS=2000

# Rate limiting (per recipient)
RATE_LIMIT_MAX_PER_HOUR=5

# Webhook callback (mocked receiver, part of this same app)
WEBHOOK_URL=http://localhost:3000/webhook/mock
